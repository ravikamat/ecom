# Core
NODE_ENV=production
PORT=3000
API_VERSION=v1
LOG_LEVEL=info

# Database
DB_PATH=./eco.db
DB_WAL=true
EVENT_STORE_PATH=./eco_events.db

# Redis
REDIS_URL=redis://localhost:6379

# AI Gateway (3-Tier)
AI_TIER1_URL=https://api.glm.ai/v1
AI_TIER1_KEY=sk-your-glm-key-here
AI_TIER2_URL=https://api.minimax.ai/v1
AI_TIER2_KEY=sk-your-minimax-key-here
AI_TIER3_URL=http://localhost:11434
AI_TIER3_MODEL=qwen3.6
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_TIMEOUT=60

# Python Bridge
PYTHON_BRIDGE_URL=http://localhost:5001
PYTHON_BRIDGE_POOL_SIZE=5

# Security
JWT_SECRET=change-me-in-production-min-32-chars-long
API_KEY_ADMIN=your-admin-api-key-here
API_RATE_LIMIT=100
API_RATE_WINDOW=60000

# Feature Flags
ENABLE_SEMANTIC_SEARCH=true
ENABLE_MULTI_AGENT=true
ENABLE_FORECASTING=true
ENABLE_EVENT_SOURCING=true

# Cold Storage
ARCHIVE_DIR=./archives
ARCHIVE_RETENTION_DAYS=90

# Discovery Stream
DISCOVERY_MAX_CONCURRENT=5
DISCOVERY_REFRESH_INTERVAL=30000
